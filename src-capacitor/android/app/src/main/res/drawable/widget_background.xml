<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted-glass dark container: makes the widget feel like a unified card on any wallpaper.
     Rounded corners clip the widget boundary on Android 12+ adaptive layouts.
     The dark overlay also guarantees white header text stays readable. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#99000000" />
    <corners android:radius="16dp" />
</shape>
