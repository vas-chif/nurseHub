rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Phase 27: Multi-Level Role Hierarchy (§1.10)
    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.get('role', 'user') == 'superAdmin';
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.get('role', 'user') == 'admin';
    }

    function isAnyAdmin() {
      return isSuperAdmin() || isAdmin();
    }

    /**
     * Config-Fencing: Check if admin has authority over a specific configuration
     */
    function hasConfigAuthority(configId) {
      return isSuperAdmin() || (isAdmin() && configId in request.auth.token.get('managedConfigIds', []));
    }

    function isOperatorOwner(configId, operatorId) {
      return isAuthenticated() && (
        // Case 1: Direct UID link on the operator document
        (resource != null && 'userId' in resource.data && resource.data.userId == request.auth.uid) ||
        // Case 2: User profile links to this operatorId and configId
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.operatorId == operatorId &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.configId == configId)
      );
    }

    /**
     * Config-Fencing (JWT-First): checks if the authenticated user belongs to a config.
     * Uses JWT claim 'configId' (zero cost). All users have the claim after migrate-claims.js ran.
     */
    function isUserInConfig(configId) {
      return isAuthenticated() &&
        request.auth.token.get('configId', '') == configId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Phase 27: manageAdmins permission required to modify other users
      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        (isAdmin() && request.auth.token.get('permissions', {}).get('manageAdmins', false) == true) ||
        (request.auth.uid == userId && (
          // Allow normal updates (excluding sensitive fields)
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isApproved', 'operatorId', 'configId', 'managerialInfo']) ||
          // Allow self-healing/migration: if the current operatorId is null OR is a legacy ID (starts with 'op-')
          (
            (resource.data.get('operatorId', null) == null || resource.data.get('operatorId', '').matches('^op-.*')) && 
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['operatorId', 'configId', 'profession', 'isVerified', 'pendingApproval', 'updatedAt'])
          )
        ))
      );
    }

    // Shift Requests
    match /shiftRequests/{requestId} {
      allow read: if isAuthenticated();
      // Only admins can create ABSENCE requests
      allow create: if isAuthenticated() && (
        request.resource.data.reason != 'ABSENCE' || isAnyAdmin()
      );
      // Config-Fencing for updates (approvals, rejections, or toggling interest)
      allow update: if hasConfigAuthority(resource.data.configId) || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['offers', 'offeringOperatorIds', 'hiddenBy'])
      );
      allow delete: if hasConfigAuthority(resource.data.configId) || 
                   (isAuthenticated() && resource != null && (resource.data.creatorId == request.auth.uid || resource.data.userId == request.auth.uid));
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAnyAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
    }
    
    // Settings & System Config (Super Admin only for global settings)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // System Configurations
    match /systemConfigurations/{configId} {
      allow read: if true;
      // Only Super Admin can create/delete configs. Authorized admins can update.
      allow create, delete: if isSuperAdmin();
      allow update: if hasConfigAuthority(configId);

      // Isolated Sync Metadata
      match /metadata/sync {
        allow read: if isAuthenticated();
        allow write: if (hasConfigAuthority(configId) || request.auth.token.get('configId', '') == configId || isUserInConfig(configId)) &&
          (resource == null || 
           request.time.toMillis() >= resource.data.lastSyncTimestamp + (hasConfigAuthority(configId) ? 60000 : 7200000) - 10000); // 10s buffer
      }
      
      match /operators/{operatorId} {
        allow read: if true;
        allow write: if hasConfigAuthority(configId) || request.auth.token.get('configId', '') == configId || isUserInConfig(configId);
        allow update: if isOperatorOwner(configId, operatorId) || (
          isAuthenticated() && 
          (!('userId' in resource.data) || resource.data.userId == null) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId']) &&
          request.resource.data.userId == request.auth.uid
        );
      }

      match /replacementScenarios/{scenarioId} {
        allow read: if isAuthenticated();
        allow write: if hasConfigAuthority(configId);
      }

      match /rotationGroups/{groupId} {
        allow read: if isAuthenticated();
        allow create, delete: if hasConfigAuthority(configId);
        allow update: if hasConfigAuthority(configId) || (
          isAuthenticated() && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isActive', 'currentColumnIndex', 'nextChangeTimestamp', 'updatedAt'])
        );
      }
    }

    // Other system documents: super admin only
    match /system/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Shift Swaps
    match /shiftSwaps/{swapId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if hasConfigAuthority(resource.data.configId) || (isAuthenticated() && (
        (resource.data.status == 'OPEN' && request.resource.data.status == 'PENDING_ADMIN' && request.resource.data.counterpartId == request.auth.uid) ||
        (resource.data.creatorId == request.auth.uid && request.resource.data.status == 'CANCELLED') ||
        (resource.data.creatorId == request.auth.uid && resource.data.status == 'OPEN' && request.resource.data.get('deletedByCreator', false) == true) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hiddenBy']))
      ));
      allow delete: if hasConfigAuthority(resource.data.configId) || (isAuthenticated() && resource != null && resource.data.creatorId == request.auth.uid);
    }

    // Backup & Audit Logs: Requires manageSystem or manageAdmins permission
    match /backupLogs/{logId}           { allow read: if isSuperAdmin() || (isAdmin() && request.auth.token.get('permissions', {}).get('manageSystem', false) == true); allow write: if false; }
    match /manualBackupLogs/{logId}     { allow read: if isSuperAdmin() || (isAdmin() && request.auth.token.get('permissions', {}).get('manageSystem', false) == true); allow write: if false; }
    match /restoreLogs/{logId}          { allow read: if isSuperAdmin() || (isAdmin() && request.auth.token.get('permissions', {}).get('manageSystem', false) == true); allow write: if false; }
    match /deletedBackupLogs/{logId}    { allow read: if isSuperAdmin() || (isAdmin() && request.auth.token.get('permissions', {}).get('manageSystem', false) == true); allow write: if false; }
    match /backupAutomationLogs/{logId} { allow read: if isSuperAdmin() || (isAdmin() && request.auth.token.get('permissions', {}).get('manageSystem', false) == true); allow write: if false; }
    match /auditLogs/{logId}            { allow read: if isSuperAdmin() || (isAdmin() && request.auth.token.get('permissions', {}).get('manageAdmins', false) == true); allow write: if false; }
    match /systemSettings/backup        { allow read: if isAnyAdmin(); allow write: if false; }
  }
}
