rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Phase 25 (§1.10): JWT-First — reads role from Custom Claim (zero Firestore reads).
    // Falls back gracefully: if claim is missing (pre-migration users), deny by default.
    // After running api/migrate-claims.js all users will have the claim set.
    function isAdmin() {
      return isAuthenticated() && request.auth.token.get('role', 'user') == 'admin';
    }

    function isOperatorOwner(operatorId) {
      return isAuthenticated() && (
        // Case 1: Direct UID link on the operator document
        (resource != null && 'userId' in resource.data && resource.data.userId == request.auth.uid) ||
        // Case 2: User profile links to this operatorId
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.operatorId == operatorId
      );
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Phase 25: Users can update their profile but NOT their role or approval status
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isApproved', 'operatorId', 'configId']))
      );
    }

    // Shift Requests
    match /shiftRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Only Admin can update/approve shift requests
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isAuthenticated() && resource != null && (resource.data.creatorId == request.auth.uid || resource.data.userId == request.auth.uid));
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
    }
    
    // Settings & System Config
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // System Configurations
    match /systemConfigurations/{configId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /operators/{operatorId} {
        allow read: if true;
        // Allow update if admin OR if the authenticated user is the legitimate owner
        allow update: if isAdmin() || isOperatorOwner(operatorId);
        allow create: if isAdmin();
      }

      match /replacementScenarios/{scenarioId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // system/syncStatus: readable & writable by any authenticated user (global sync cooldown)
    match /system/syncStatus {
      allow read, write: if isAuthenticated();
    }

    // Other system documents: admin only
    match /system/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Shift Swaps (Phase 20)
    match /shiftSwaps/{swapId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Hardening: Only Admin can approve/finalize swaps.
      // Involved parties can only update the status to 'ACCEPTED' or 'CANCELLED'.
      allow update: if isAdmin() || (isAuthenticated() && (
        (isOperatorOwner(resource.data.targetOperatorId) && request.resource.data.status == 'ACCEPTED') ||
        (resource.data.creatorId == request.auth.uid && request.resource.data.status == 'CANCELLED')
      ));
      allow delete: if isAdmin() || (isAuthenticated() && resource != null && resource.data.creatorId == request.auth.uid);
    }
  }
}
