rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Phase 25 (§1.10): JWT-First — reads role from Custom Claim (zero Firestore reads).
    // Falls back gracefully: if claim is missing (pre-migration users), deny by default.
    // After running api/migrate-claims.js all users will have the claim set.
    function isAdmin() {
      return isAuthenticated() && request.auth.token.get('role', 'user') == 'admin';
    }

    function isOperatorOwner(operatorId) {
      return isAuthenticated() && (
        // Case 1: Direct UID link on the operator document
        (resource != null && 'userId' in resource.data && resource.data.userId == request.auth.uid) ||
        // Case 2: User profile links to this operatorId
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.operatorId == operatorId
      );
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Phase 25: Users can update their profile but NOT their role or approval status
      // ALLOW linking operatorId/configId ONLY IF they are currently null (first-time sync)
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && (
          // Standard update: role, isApproved, operatorId, configId are protected
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isApproved', 'operatorId', 'configId']) ||
          // Linking exception: allow setting operatorId and configId if they don't exist yet
          (resource.data.get('operatorId', null) == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['operatorId', 'configId', 'profession', 'isVerified', 'pendingApproval', 'updatedAt']))
        ))
      );
    }

    // Shift Requests
    match /shiftRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Allow update if admin OR if a user is adding an offer (only modifying offers and offeringOperatorIds)
      allow update: if isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['offers', 'offeringOperatorIds'])
      );
      allow delete: if isAdmin() || (isAuthenticated() && resource != null && (resource.data.creatorId == request.auth.uid || resource.data.userId == request.auth.uid));
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
    }
    
    // Settings & System Config
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // System Configurations
    match /systemConfigurations/{configId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /operators/{operatorId} {
        allow read: if true;
        // Allow update if admin OR if the authenticated user is the legitimate owner
        // OR if the operator is "orphan" (no userId) and the user is claiming it with their own UID
        allow update: if isAdmin() || isOperatorOwner(operatorId) || (
          isAuthenticated() && 
          (!('userId' in resource.data) || resource.data.userId == null) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId']) &&
          request.resource.data.userId == request.auth.uid
        );
        allow create: if isAdmin();
      }

      match /replacementScenarios/{scenarioId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // system/syncStatus: readable & writable by any authenticated user (global sync cooldown)
    match /system/syncStatus {
      allow read, write: if isAuthenticated();
    }

    // Other system documents: admin only
    match /system/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Shift Swaps (Phase 20)
    match /shiftSwaps/{swapId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Hardening: Only Admin can approve/finalize swaps.
      // Involved parties can only update the status to 'PENDING_ADMIN' (accepting) or 'CANCELLED' (by creator).
      allow update: if isAdmin() || (isAuthenticated() && (
        // Allow accepting an OPEN swap: status must become PENDING_ADMIN, and counterpartId must be the current user
        (resource.data.status == 'OPEN' && request.resource.data.status == 'PENDING_ADMIN' && request.resource.data.counterpartId == request.auth.uid) ||
        // Allow creator to cancel
        (resource.data.creatorId == request.auth.uid && request.resource.data.status == 'CANCELLED')
      ));
      allow delete: if isAdmin() || (isAuthenticated() && resource != null && resource.data.creatorId == request.auth.uid);
    }
  }
}
